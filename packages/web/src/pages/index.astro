---
import Layout from '../layouts/Layout.astro';
import { Button, Badge } from '@pasele-guerita/ui';
import { AddToCartButton } from '../components/AddToCartButton';
import { cookieFlavors, breadFlavors, monthlySpecial, allProducts } from '@pasele-guerita/core';

let displayCookies: any[] = cookieFlavors;
let displayBreads: any[] = breadFlavors;
try {
    const origin = Astro.url.origin;
    const res = await fetch(`${origin}/api/storefront-data`);
    if (res.ok) {
        const data = await res.json();
        if (data.cookies?.length > 0) displayCookies = data.cookies.map((c: any) => {
            const s = cookieFlavors.find((sf: any) => sf.id === c.id || sf.name === c.name) || {};
            return { ...s, ...c, image: c.image || (s as any).image, description: c.description ?? (s as any).description };
        });
        if (data.breads?.length > 0) displayBreads = data.breads.map((b: any) => {
            const s = breadFlavors.find((sf: any) => sf.id === b.id || sf.name === b.name) || {};
            return { ...s, ...b, image: b.image || (s as any).image, description: b.description ?? (s as any).description };
        });
    }
} catch (e) {}

// A fixed pool of extra images for hover swaps — different from the product image pool
const cookieHoverPool = [
    '/imagenes/cookie-abuelita-2.webp',
    '/imagenes/cookie-choconuts-2.webp',
    '/imagenes/cookie-chai.webp',
    '/imagenes/cookie-dragon.webp',
    '/imagenes/IMG_6654.webp',
    '/imagenes/IMG_6658.webp',
    '/imagenes/IMG_6662.webp',
];
const breadHoverPool = [
    '/imagenes/hogaza-natural-2.webp',
    '/imagenes/hogaza-semillas-2.webp',
    '/imagenes/hogaza-centeno.webp',
    '/imagenes/hogaza-proceso.webp',
];
---

<Layout title="Home">
	<!-- Announcement Bar -->
	<div class="bg-primary text-bg text-center py-3 font-bold text-sm tracking-wide">
		Próxima entrega: Sábado 18 de Noviembre. ¡Quedan pocos lugares!
	</div>

	<!-- Hero Section with Carousel -->
	<section class="relative overflow-hidden min-h-[85vh] flex items-center" id="hero-section">
		<div class="absolute inset-0 z-0" id="hero-carousel">
			{[
				{ src: '/imagenes/IMG_6657.webp', alt: 'Choco Nuts cookie' },
				{ src: '/imagenes/hogaza-natural.webp', alt: 'Hogaza Natural' },
				{ src: '/imagenes/IMG_6360.webp', alt: 'Mango Coco cookie' },
				{ src: '/imagenes/hogaza-proceso.webp', alt: 'Panes fermentando' },
			].map((slide, i) => (
				<div class={`hero-slide absolute inset-0 transition-opacity duration-1000 ${i === 0 ? 'opacity-100' : 'opacity-0'}`} data-index={i}>
					<img src={slide.src} alt={slide.alt} class="w-full h-full object-cover" style="transform: scale(1.05);" fetchpriority={i === 0 ? 'high' : 'low'} loading={i === 0 ? 'eager' : 'lazy'} />
					<div class="absolute inset-0 bg-gradient-to-r from-white/95 via-white/80 to-white/20"></div>
				</div>
			))}
		</div>
		<div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex gap-3 z-20">
			{[0,1,2,3].map((i) => (
				<button class={`hero-dot rounded-full transition-all duration-300 h-3 ${i === 0 ? 'bg-primary w-8' : 'bg-primary/30 w-3'}`} data-dot={i} aria-label={`Slide ${i+1}`}></button>
			))}
		</div>
		<div class="relative z-10 max-w-7xl mx-auto px-6 py-20 w-full">
			<div class="max-w-2xl">
				<Badge variant="accent" className="mb-6">Lotes Pequeños</Badge>
				<h1 class="text-5xl md:text-6xl lg:text-7xl font-serif text-primary mb-6 leading-tight">
					Pan y galletas naturales, sin conservadores y con ingredientes de verdad.
				</h1>
				<p class="text-xl text-gray-700 font-bold mb-8 max-w-lg leading-relaxed font-serif italic">
					<strong>En Dallas</strong>, encontrar pan artesanal de calidad y postres hechos con ingredientes reales es todo un reto… hasta que llegó <strong>nuestra Güerita</strong>.
				</p>
				<p class="text-lg text-gray-700 mb-6 max-w-lg leading-relaxed">
					Nuestras galletas, elaboradas con masa madre, tienen una <strong>complejidad y profundidad de sabor</strong> que las hace únicas. Nuestros panes rústicos pasan por una <strong>fermentación natural de más de 20 horas</strong>.
				</p>
				<div class="flex flex-col sm:flex-row gap-4">
					<a href="#menu"><Button variant="outline" className="w-full sm:w-auto text-lg h-14 px-8">Ver Menú</Button></a>
					<a href="/checkout"><Button variant="primary" className="w-full sm:w-auto text-lg h-14 px-8 shadow-lg">Comprar Ahora</Button></a>
				</div>
			</div>
		</div>
	</section>

	<!-- Slim Fast Marquee -->
	<div class="pg-marquee-wrap overflow-hidden bg-primary py-3">
		<div class="pg-marquee-inner flex gap-3" aria-hidden="true">
			{[
				'/imagenes/cookie-choconuts.webp','/imagenes/hogaza-natural.webp','/imagenes/IMG_6360.webp',
				'/imagenes/IMG_6758.webp','/imagenes/hogaza-semillas.webp','/imagenes/cookie-dragon.webp',
				'/imagenes/cookie-choconuts.webp','/imagenes/hogaza-natural.webp','/imagenes/IMG_6360.webp',
				'/imagenes/IMG_6758.webp','/imagenes/hogaza-semillas.webp','/imagenes/cookie-dragon.webp',
			].map((src) => (
				<div class="flex-shrink-0 w-28 h-28 rounded-xl overflow-hidden border-2 border-white/10">
					<img src={src} alt="" class="w-full h-full object-cover" loading="lazy" decoding="async" />
				</div>
			))}
		</div>
	</div>

	<!-- Scarcity with side image -->
	<section class="py-20 bg-bg">
		<div class="max-w-6xl mx-auto px-6 grid md:grid-cols-2 gap-12 items-center">
			<div class="text-center md:text-left">
				<h2 class="font-serif text-4xl md:text-5xl text-primary mb-8 leading-tight">Nuestra producción es limitada.</h2>
				<p class="text-xl text-gray-700 leading-relaxed mb-8">
					Horneamos lotes pequeños para garantizar la calidad. Solo abrimos pedidos una vez al mes.
					<strong class="text-primary block mt-4 text-2xl italic font-serif">Si parpadeas, te quedas sin tu Sourdough.</strong>
				</p>
				<Badge variant="error" className="text-sm md:text-base px-6 py-3">Cupos limitados por punto de entrega</Badge>
			</div>
			<div class="grid grid-cols-2 gap-3">
				<img src="/imagenes/IMG_6662.webp" alt="Galletas artesanales" class="rounded-3xl w-full h-48 object-cover shadow-lg" loading="lazy" />
				<img src="/imagenes/IMG_6749.webp" alt="Pan artesanal" class="rounded-3xl w-full h-48 object-cover shadow-lg mt-6" loading="lazy" />
			</div>
		</div>
	</section>

	<!-- Favoritos Section - MOVED TO TOP -->
	<div class="mb-24 py-16 px-8 bg-primary/5 rounded-[4rem] border border-primary/10">
		<div class="max-w-7xl mx-auto">
			<div class="flex flex-col md:flex-row md:items-end justify-between mb-12 gap-6">
				<div>
					<h3 class="font-serif text-4xl text-primary mb-2">✨ Los Favoritos</h3>
					<p class="text-gray-500 uppercase tracking-widest font-bold text-xs">Recomendaciones de la casa</p>
				</div>
				<a href="/#menu" class="text-primary font-bold border-b-2 border-primary/20 pb-1 hover:border-primary transition-all">Ver menú completo →</a>
			</div>
			<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
				{[
					allProducts.find(p => p.id === 'abuelita'),
					allProducts.find(p => p.id === 'fresa-coco'),
					allProducts.find(p => p.id === 'jalapeño-cheddar')
				].filter(Boolean).map((fav: any) => (
						<div class="bg-white p-6 rounded-3xl shadow-sm border border-bg hover:shadow-xl transition-all group overflow-hidden relative">
							<div class="relative h-64 -mx-6 -mt-6 mb-6 overflow-hidden">
								<img src={fav.image} alt={fav.name} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
								<div class="absolute top-4 left-4 bg-white/90 backdrop-blur-md px-4 py-1.5 rounded-full text-primary text-xs font-bold shadow-sm">Popular</div>
							</div>
							<h4 class="font-serif text-2xl text-primary mb-2">{fav.name}</h4>
							<p class="text-gray-600 text-sm mb-4 line-clamp-2">{fav.description}</p>
							<a href="/checkout" class="inline-flex items-center text-primary font-bold gap-2 text-sm text-primary">Agregar al carrito <span class="group-hover:translate-x-1 transition-transform">→</span></a>
						</div>
				))}
			</div>
		</div>
	</div>

	<!-- Mensaje de Marca (Sourdough para cada ocasión) - MOVED TO TOP -->
	<div class="mb-24 py-20 bg-primary rounded-[3rem] text-bg overflow-hidden relative">
		<div class="absolute top-0 right-0 w-96 h-96 bg-accent opacity-10 rounded-full -translate-y-1/2 translate-x-1/2 blur-[80px]"></div>
		<div class="max-w-6xl mx-auto px-8 relative z-10">
			<div class="text-center mb-16">
				<h3 class="font-serif text-4xl md:text-5xl mb-6">Sourdough para cada ocasión</h3>
				<div class="w-24 h-1 bg-accent/30 mx-auto rounded-full"></div>
			</div>
			<div class="grid md:grid-cols-2 gap-12">
				<div class="bg-white/5 backdrop-blur-sm p-10 rounded-[2.5rem] border border-white/10 hover:bg-white/10 transition-colors">
					<span class="text-5xl mb-6 block">✨</span>
					<h4 class="font-serif text-3xl mb-4">Para tus eventos</h4>
					<p class="text-bg/80 text-lg leading-relaxed">¿Tienes una cena o reunión especial? Personalizamos nuestras cajas de galletas y hogazas para que tu evento tenga el toque artesanal único de Pásele Güerita.</p>
				</div>
				<div class="bg-white/5 backdrop-blur-sm p-10 rounded-[2.5rem] border border-white/10 hover:bg-white/10 transition-colors">
					<span class="text-5xl mb-6 block">💼</span>
					<h4 class="font-serif text-3xl mb-4">Para tu negocio</h4>
					<p class="text-bg/80 text-lg leading-relaxed font-bold">Venta Wholesale</p>
					<p class="text-bg/80 text-lg leading-relaxed">Lleva la magia de nuestra masa madre a tu café o restaurante. Ofrecemos precios de mayoreo para aliados comerciales que buscan calidad superior.</p>
				</div>
			</div>
		</div>
	</div>

	<!-- Testimonials with images -->
	<section class="py-20 bg-white border-y border-bg">
		<div class="max-w-7xl mx-auto px-6">
			<h2 class="font-serif text-3xl md:text-4xl text-center text-primary mb-12 italic font-medium">"Hecho en Dallas para los que extrañan el sabor real de casa."</h2>
			<div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
				<div class="bg-bg p-8 rounded-3xl relative hover:-translate-y-2 transition-transform duration-300">
					<span class="text-7xl text-accent absolute -top-6 left-6 font-serif opacity-50">"</span>
					<p class="text-gray-700 text-lg mb-6 italic mt-4 relative z-10">El primer pan en años que no me inflama. Las galletas de Matcha son espectaculares.</p>
					<p class="font-bold text-primary">— Mariana L., Uptown</p>
				</div>
				<div class="overflow-hidden rounded-3xl h-64 shadow-md">
					<img src="/imagenes/IMG_6754.webp" alt="Nuestros productos" class="w-full h-full object-cover" loading="lazy" 
					onerror="this.src='/imagenes/IMG_6658.webp'" />
				</div>
				<div class="bg-bg p-8 rounded-3xl relative hover:-translate-y-2 transition-transform duration-300">
					<span class="text-7xl text-accent absolute -top-6 left-6 font-serif opacity-50">"</span>
					<p class="text-gray-700 text-lg mb-6 italic mt-4 relative z-10">Vale cada centavo. Se nota el amor y las 24 horas de fermentación. No vuelvo al pan de caja.</p>
					<p class="font-bold text-primary">— Roberto C., Oak Cliff</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Products Section -->
	<section id="menu" class="py-20 max-w-7xl mx-auto px-6">
			<div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-6">
				<div>
					<h2 class="font-serif text-4xl md:text-6xl text-primary mb-2">Nuestro Menú</h2>
				</div>
				<a href="/checkout"><Button variant="primary" className="text-xl px-12 h-16 shadow-xl hover:scale-105 transition-transform duration-300">Hacer Pedido Ahora</Button></a>
		</div>


		<!-- Galletas -->
		<div class="mb-20">
			<h3 class="font-serif text-3xl text-primary italic mb-2">🍪 Galletas Artesanales</h3>
			<p class="text-gray-500 mb-8 text-sm">Set de 3 galletas por caja &bull; Horneadas con masa madre</p>
			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
				{displayCookies.map((flavor: any, i: number) => {
					const mainImg = flavor.image || cookieFlavors[i % cookieFlavors.length]?.image || '/imagenes/IMG_6657.webp';
					const hoverImg = cookieHoverPool[i % cookieHoverPool.length];
					return (
						<div class="product-card group bg-white rounded-3xl overflow-hidden shadow-md border border-bg flex flex-col hover:scale-[1.02] transition-transform duration-300">
							<a href={`/product/${flavor.id}`} class="flex-1 flex flex-col">
								<div class="product-img-wrap relative w-full h-56 overflow-hidden bg-gray-100 flex items-center justify-center">
									<img src={mainImg || '/logo.png'} alt={flavor.name} class={`product-img-main absolute inset-0 w-full h-full object-cover ${!mainImg ? 'opacity-20 object-contain p-8' : ''}`} loading="lazy" decoding="async" />
									<img src={hoverImg} alt={flavor.name + ' detalle'} class="product-img-hover absolute inset-0 w-full h-full object-cover opacity-0" loading="lazy" decoding="async" />
									{flavor.is_sugar_free && (
										<div class="absolute top-3 right-3 bg-blue-100 text-blue-700 text-[9px] font-bold uppercase tracking-widest px-2 py-1 rounded shadow border border-blue-200 z-10">Sugar Free</div>
									)}
								</div>
								<div class="p-6 bg-white relative">
    <div class="flex justify-between items-start mb-2">
        <h3 class="font-serif text-2xl text-primary italic leading-tight">{flavor.name}</h3>
        <span class="text-sm font-bold text-primary">${flavor.price ? (flavor.price / 3).toFixed(2) : '4.00'} c/u</span>
    </div>
    <p class="text-xs text-gray-500 line-clamp-2 mb-4 italic font-serif opacity-70">
        {flavor.description}
    </p>
    <div class="flex items-center gap-2 mb-6">
        <span class="text-[8px] font-black uppercase tracking-widest text-accent bg-accent/5 px-2 py-0.5 rounded-full whitespace-nowrap">Plan de caja disponible</span>
        <div class="h-[1px] flex-1 bg-accent/10"></div>
    </div>
    
    <AddToCartButton client:load product={{...flavor, category: 'cookie', price: 12, boxSize: 3}} />
    {flavor.ingredients && <p class="text-[10px] text-gray-400 italic mt-4">{flavor.ingredients}</p>}
</div>
							</a>
						</div>
					);
				})}
			</div>
		</div>

		<!-- Pan de Masa Madre -->
		<div class="mb-20">
			<h3 class="font-serif text-3xl text-primary italic mb-2">🍞 Pan de Masa Madre</h3>
			<p class="text-gray-500 mb-8 text-sm">Hogaza entera &bull; Fermentación lenta 48 horas</p>
			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
				{displayBreads.map((bread: any, i: number) => {
					const mainImg = bread.image || breadFlavors[i % breadFlavors.length]?.image || '/imagenes/IMG_6703.webp';
					const hoverImg = breadHoverPool[i % breadHoverPool.length];
					return (
						<div class="product-card group bg-white rounded-3xl overflow-hidden shadow-md border border-bg flex flex-col hover:scale-[1.02] transition-transform duration-300">
							<a href={`/product/${bread.id}`} class="flex-1 flex flex-col">
								<div class="product-img-wrap relative w-full h-56 overflow-hidden bg-gray-100 flex items-center justify-center">
									<img src={mainImg || '/logo.png'} alt={bread.name} class={`product-img-main absolute inset-0 w-full h-full object-cover ${!mainImg ? 'opacity-20 object-contain p-8' : ''}`} loading="lazy" decoding="async" />
									<img src={hoverImg} alt={bread.name + ' detalle'} class="product-img-hover absolute inset-0 w-full h-full object-cover opacity-0" loading="lazy" decoding="async" />
								</div>
								<div class="p-6 bg-white">
                                    <div class="flex justify-between items-start mb-2">
                                        <h3 class="font-serif text-2xl text-primary italic leading-tight">{bread.name}</h3>
                                        <span class="text-sm font-bold text-primary">${bread.price || 18}</span>
                                    </div>
                                    <p class="text-xs text-gray-500 line-clamp-2 mb-6 italic font-serif opacity-70">
                                        {bread.description}
                                    </p>
                                    
                                    <AddToCartButton client:load product={{...bread, category: 'bread'}} />
                                </div>
							</a>
						</div>
					);
				})}
			</div>
		</div>

		<!-- Simple 4-column photo grid (Gallery) -->
		<div class="mb-20">
			<p class="font-serif text-xl text-primary/40 italic text-center mb-6">Del horno al corazón 🫶</p>
			<div class="grid grid-cols-4 md:grid-cols-4 gap-3">
				{[
					'/imagenes/IMG_6654.webp', '/imagenes/IMG_6662.webp', '/imagenes/IMG_6658.webp', '/imagenes/IMG_6753.webp',
					'/imagenes/IMG_6755.webp', '/imagenes/IMG_6756.webp', '/imagenes/IMG_6532.webp', '/imagenes/IMG_6750.webp',
				].map((src) => (
					<div class="aspect-square rounded-2xl overflow-hidden shadow-sm hover:shadow-md hover:scale-[1.02] transition-all duration-200">
						<img src={src} alt="Pásele Güerita" class="w-full h-full object-cover" loading="lazy" decoding="async" />
					</div>
				))}
			</div>
		</div>
		</div>

		<!-- Mensaje de Marca (Sourdough para cada ocasión) - REMOVED from bottom -->

		<!-- Contact Section -->
		<section class="py-20 mt-20 -mx-6 px-6">
			<div class="bg-white rounded-[3rem] p-10 md:p-16 shadow-xl border border-accent/10 relative overflow-hidden">
				<div class="absolute -bottom-20 -right-20 w-80 h-80 bg-accent/10 rounded-full blur-[100px]"></div>
				<div class="grid md:grid-cols-2 gap-16 mb-12 relative z-10">
					<div>
						<h2 class="font-serif text-4xl lg:text-5xl text-primary mb-6">Escríbenos Pásele Güerita ❤️</h2>
						<p class="text-xl text-gray-700 leading-relaxed font-serif max-w-xl mb-10">
							En nuestro horno creemos que las mejores decisiones son las que alimentan el alma.
						</p>
						<a href="https://wa.me/14303242593" target="_blank" rel="noopener noreferrer">
							<Button variant="outline" className="h-14 px-10 text-xl font-serif hover:bg-primary hover:text-white transition-all">Contáctanos</Button>
						</a>
					</div>
					<div class="flex flex-col justify-center border-t md:border-t-0 md:border-l border-accent/20 pt-10 md:pt-0 md:pl-14">
						<div class="bg-accent/5 p-8 rounded-[2rem] border border-accent/10 hover:bg-accent/10 transition-colors">
							<p class="font-bold text-primary text-xl mb-3 flex items-center gap-3"><span class="text-3xl">🍞</span> Suscripciones Semanales</p>
							<p class="text-gray-600 text-lg leading-relaxed">Pregunta por nuestras suscripciones: te entregamos tu pan rebanado sin costo adicional.</p>
						</div>
					</div>
				</div>
				<div class="grid grid-cols-1 sm:grid-cols-3 gap-5 pt-10 border-t border-accent/20 relative z-10">
					<div class="flex items-center gap-4 bg-white p-5 rounded-2xl border border-accent/5 shadow-sm hover:shadow-md transition-shadow">
						<span class="text-3xl">📞</span>
						<div><p class="text-[10px] uppercase tracking-[0.2em] text-gray-400 font-bold mb-1">WhatsApp</p><p class="font-bold text-primary text-xl">+1 430 324 2593</p></div>
					</div>
					<div class="flex items-center gap-4 bg-white p-5 rounded-2xl border border-accent/5 shadow-sm hover:shadow-md transition-shadow">
						<span class="text-3xl">📍</span>
						<div><p class="text-[10px] uppercase tracking-[0.2em] text-gray-400 font-bold mb-1">Ubicación</p><p class="font-bold text-primary text-xl uppercase">Dallas - Farmersville TX</p></div>
					</div>
					<div class="flex items-center gap-4 bg-white p-5 rounded-2xl border border-accent/5 shadow-sm hover:shadow-md transition-shadow">
						<span class="text-3xl">📲</span>
						<div><p class="text-[10px] uppercase tracking-[0.2em] text-gray-400 font-bold mb-1">Redes</p><p class="font-bold text-primary text-xl italic">@paselegueritatx</p></div>
					</div>
				</div>
			</div>
		</section>
	</section>
</Layout>

<style>
/* GPU marquee — proper infinite loop */
.pg-marquee-wrap { height: 7rem; overflow: hidden; position: relative; background: var(--color-primary, #2d5a4e); }
.pg-marquee-inner {
	position: absolute;
	display: flex;
	gap: 0.75rem;
	width: max-content;
	will-change: transform;
	animation: pg-scroll 28s linear infinite;
}
@keyframes pg-scroll {
	from { transform: translateX(0); }
	to   { transform: translateX(-50%); }
}

/* Product card hover image swap */
.product-card { transition: box-shadow 0.2s, transform 0.2s; }
.product-card:hover { box-shadow: 0 20px 50px rgba(0,0,0,.12); transform: translateY(-4px); }
.product-img-main, .product-img-hover { transition: opacity 0.25s ease; }
.product-card:hover .product-img-main { opacity: 0; }
.product-card:hover .product-img-hover { opacity: 1; }
</style>

<script>
// Hero carousel
const slides = document.querySelectorAll('.hero-slide');
const dots = document.querySelectorAll('.hero-dot');
let current = 0;
function goTo(n: number) {
	(slides[current] as HTMLElement).style.opacity = '0';
	dots[current].classList.remove('w-8', 'bg-primary');
	dots[current].classList.add('w-3', 'bg-primary/30');
	current = n;
	(slides[current] as HTMLElement).style.opacity = '1';
	dots[current].classList.add('w-8', 'bg-primary');
	dots[current].classList.remove('w-3', 'bg-primary/30');
}
dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));
setInterval(() => goTo((current + 1) % slides.length), 5000);
</script>
