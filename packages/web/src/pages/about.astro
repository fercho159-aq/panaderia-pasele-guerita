---
// Legacy URL — redirect to localized version with browser-language detection.
const acceptLanguage = Astro.request.headers.get('accept-language') ?? '';
const prefersEnglish = /^en\b|,\s*en\b/i.test(acceptLanguage) && !/^es\b|,\s*es\b/i.test(acceptLanguage);
const lang = prefersEnglish ? 'en' : 'es';
return Astro.redirect(`/${lang}/about`, 302);
---
