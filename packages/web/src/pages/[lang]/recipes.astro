---
import Layout from '../../layouts/Layout.astro';
import { Button } from '@pasele-guerita/ui';
import { RecipeBuyButton } from '../../components/RecipeBuyButton';
import { isValidLang, useTranslations, localizedPath, type Language } from '../../i18n/translations';

const { lang: langParam } = Astro.params;
if (!isValidLang(langParam)) {
    return Astro.redirect('/es/recipes');
}
const lang: Language = langParam;
const tr = useTranslations(lang);

const recipes = [
    {
        id: 'recipe-starter',
        titleKey: 'recipes.items.starter.title',
        descKey: 'recipes.items.starter.description',
        tagKey: 'recipes.items.starter.tag',
        price: 5.00,
        image: '/imagenes/IMG_6703.webp',
    },
    {
        id: 'recipe-cookies',
        titleKey: 'recipes.items.cookies.title',
        descKey: 'recipes.items.cookies.description',
        tagKey: 'recipes.items.cookies.tag',
        price: 5.00,
        image: '/imagenes/IMG_6657.webp',
    },
    {
        id: 'recipe-tips',
        titleKey: 'recipes.items.tips.title',
        descKey: 'recipes.items.tips.description',
        tagKey: 'recipes.items.tips.tag',
        price: 5.00,
        image: '/imagenes/IMG_6751.webp',
    }
];

const inspirationImages = [
    '/imagenes/IMG_6658.webp',
    '/imagenes/IMG_6662.webp',
    '/imagenes/IMG_6750.webp',
    '/imagenes/IMG_6753.webp',
    '/imagenes/IMG_6755.webp',
    '/imagenes/IMG_6756.webp',
];

const checkoutUrl = localizedPath(lang, '/checkout');
---

<Layout title={tr('recipes.metaTitle')} lang={lang}>
    <div class="py-24 bg-bg">
		<div class="max-w-7xl mx-auto px-6">
			<div class="mb-16">
				<h1 class="font-serif text-4xl sm:text-6xl md:text-8xl text-primary mb-6 leading-tight italic" set:html={tr('recipes.heroTitle')}></h1>
				<p class="font-sans text-2xl md:text-3xl font-bold text-primary/70 mb-12 italic leading-relaxed">
					{tr('recipes.heroSubtitle')}
				</p>
			</div>
    </div>

    <div class="max-w-6xl mx-auto px-6 py-16 animate-fade-in">
        <p class="text-xl text-gray-600 font-sans text-center mb-16 max-w-2xl mx-auto">
            {tr('recipes.intro')}
        </p>

        <div class="grid md:grid-cols-3 gap-8 mb-20">
            {recipes.map((recipe) => {
                const title = tr(recipe.titleKey);
                return (
                    <div class="group relative rounded-[2rem] overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-500 hover:-translate-y-2 flex flex-col min-h-[480px]">
                        <div class="absolute inset-0">
                            <img src={recipe.image} alt={title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
                            <div class="absolute inset-0 bg-gradient-to-t from-primary/95 via-primary/60 to-primary/20"></div>
                        </div>

                        <div class="relative z-10 flex flex-col flex-1 p-8 justify-end">
                            <span class="inline-block px-3 py-1 bg-white/20 backdrop-blur-sm text-white text-xs font-bold uppercase rounded-full mb-4 font-sans tracking-wide w-max border border-white/30">
                                {tr(recipe.tagKey)}
                            </span>
                            <h2 class="font-serif text-3xl text-white font-bold mb-4 leading-tight">{title}</h2>
                            <p class="text-white/80 mb-8 font-sans text-base leading-relaxed">{tr(recipe.descKey)}</p>
                            <RecipeBuyButton client:load recipeId={recipe.id} recipeName={title} recipePrice={recipe.price} recipeImage={recipe.image} />
                        </div>
                    </div>
                );
            })}
        </div>

        <div class="mb-16">
            <h2 class="font-serif text-4xl text-primary italic text-center mb-10">{tr('recipes.galleryTitle')}</h2>
            <div class="grid grid-cols-3 md:grid-cols-6 gap-3">
                {inspirationImages.map((src) => (
                    <div class="aspect-square rounded-2xl overflow-hidden shadow-md hover:shadow-xl hover:scale-105 transition-all duration-500 cursor-pointer">
                        <img src={src} alt="Pásele Güerita" class="w-full h-full object-cover" loading="lazy" />
                    </div>
                ))}
            </div>
        </div>

        <div class="text-center bg-accent/10 rounded-3xl p-12 border border-accent/20">
            <h2 class="font-serif text-4xl text-primary italic mb-4">{tr('recipes.ctaTitle')}</h2>
            <p class="text-gray-600 text-xl mb-8 font-serif">{tr('recipes.ctaSubtitle')}</p>
            <a href={checkoutUrl}><Button variant="primary" className="h-14 px-12 text-xl shadow-xl hover:scale-105 transition-transform">{tr('recipes.ctaButton')}</Button></a>
        </div>
    </div>
</Layout>
