---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Artisanal Sourdough Dallas, Handmade Cookies" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Pásele Güerita</title>
		<meta name="description" content={description} />
		
		<!-- SEO -->
		<meta name="keywords" content="Artisanal Sourdough Dallas, Limited Edition Cookies, Healthy Bread Dallas, Texas Bakery" />
		<!-- LocalBusiness Schema -->
		<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@type": "LocalBusiness",
			"name": "Pásele Güerita",
			"image": "https://paseleguerita.com/logo.png",
			"address": {
				"@type": "PostalAddress",
				"addressLocality": "Dallas",
				"addressRegion": "TX",
				"addressCountry": "US"
			},
			"description": "Artisanal Sourdough Bakery in Dallas, Texas.",
			"priceRange": "$$"
		}
		</script>
	</head>
	<body class="bg-bg font-sans text-gray-900">
		<nav class="bg-white/80 backdrop-blur-md sticky top-0 z-50 border-b border-bg">
			<div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
				<a href="/" class="flex flex-col justify-center">
					<img src="/logo.png" alt="Pásele Güerita" class="h-20 sm:h-24 w-auto drop-shadow-sm" />
				</a>
				<div class="hidden md:flex space-x-8 font-serif text-2xl font-bold border-l border-primary/20 pl-8">
					<a href="/" class="hover:text-accent transition-colors">Menú</a>
					<a href="/about" class="hover:text-accent transition-colors">Quiénes somos</a>
					<a href="/recipes" class="hover:text-accent transition-colors">Recetas</a>
					<a href="/checkout" class="text-primary hover:text-accent font-black transition-colors">Carrito</a>
				</div>
                <div class="md:hidden">
                    <a href="/checkout" class="text-primary font-serif font-black text-2xl">Carrito</a>
                </div>
			</div>
		</nav>
		<main>
			<slot />
		</main>
		<footer class="bg-primary text-bg py-12 mt-20">
			<div class="max-w-7xl mx-auto px-6 text-center">
				<div class="bg-white p-3 rounded-2xl md:rounded-3xl inline-block mb-8 shadow-sm">
					<img src="/logo.png" alt="Pásele Güerita" class="h-16 md:h-20 w-auto mx-auto" />
				</div>
				<h2 class="font-serif text-4xl md:text-5xl font-bold mb-6 italic">Hecho con masa madre y mucho amor.</h2>
				<div class="font-sans flex justify-center gap-6 mb-8 text-lg font-bold opacity-90">
                    <a href="/" class="hover:text-accent transition-colors">Inicio</a>
                    <a href="/about" class="hover:text-accent transition-colors">Historia</a>
                    <a href="/legal" class="hover:text-accent transition-colors">Aviso Legal</a>
                </div>
                <p class="font-sans text-bg/60 text-sm">Dallas, Texas | Artisanal Bakery</p>
			</div>
		</footer>
	</body>
</html>
