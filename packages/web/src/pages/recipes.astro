---
import Layout from '../layouts/Layout.astro';
import { Button } from '@pasele-guerita/ui';
import { RecipeBuyButton } from '../components/RecipeBuyButton';

const recipes = [
    {
        id: 'recipe-starter',
        title: "Guía: Inicia tu propia Masa Madre",
        description: "Un PDF paso a paso para crear, alimentar y mantener tu Sourdough Starter desde cero hasta tu primer pan.",
        price: 5.00,
        tag: "Básico",
        image: "/imagenes/IMG_6703.webp",
    },
    {
        id: 'recipe-cookies',
        title: "Receta: Classic Sourdough Cookies",
        description: "Nuestra receta secreta base para que intentes hornear nuestras famosas galletas en casa.",
        price: 5.00,
        tag: "Intermedio",
        image: "/imagenes/IMG_6657.webp",
    },
    {
        id: 'recipe-tips',
        title: "Tips de Horneado y Tiempos Largos",
        description: "Información valiosa sobre fermentación en frío, autolisis y desarrollo de sabor para panaderos caseros.",
        price: 5.00,
        tag: "Avanzado",
        image: "/imagenes/IMG_6751.webp",
    }
];

const inspirationImages = [
    '/imagenes/IMG_6658.webp',
    '/imagenes/IMG_6662.webp',
    '/imagenes/IMG_6750.webp',
    '/imagenes/IMG_6753.webp',
    '/imagenes/IMG_6755.webp',
    '/imagenes/IMG_6756.webp',
];
---

<Layout title="Recetas y Guías">
    <div class="py-24 bg-bg">
		<div class="max-w-7xl mx-auto px-6">
			<div class="mb-16">
				<h1 class="font-serif text-4xl sm:text-6xl md:text-8xl text-primary mb-6 leading-tight italic">Nuestras <br/> Recetas</h1>
				<p class="font-sans text-2xl md:text-3xl font-bold text-primary/70 mb-12 italic leading-relaxed">
					Explora formas creativas de disfrutar nuestro pan y galletas.
				</p>
			</div>
    </div>

    <div class="max-w-6xl mx-auto px-6 py-16 animate-fade-in">
        <p class="text-xl text-gray-600 font-sans text-center mb-16 max-w-2xl mx-auto">
            Descarga gratis nuestras guías y recetas oficiales listas para imprimir. Lleva el sabor de Pásele Güerita a tu propia cocina.
        </p>

        <!-- Recipe Cards with Background Images -->
        <div class="grid md:grid-cols-3 gap-8 mb-20">
            {recipes.map((recipe) => (
                <div class="group relative rounded-[2rem] overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-500 hover:-translate-y-2 flex flex-col min-h-[480px]">
                    <!-- Background Image -->
                    <div class="absolute inset-0">
                        <img src={recipe.image} alt={recipe.title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
                        <div class="absolute inset-0 bg-gradient-to-t from-primary/95 via-primary/60 to-primary/20"></div>
                    </div>

                    <!-- Content overlaid -->
                    <div class="relative z-10 flex flex-col flex-1 p-8 justify-end">
                        <span class="inline-block px-3 py-1 bg-white/20 backdrop-blur-sm text-white text-xs font-bold uppercase rounded-full mb-4 font-sans tracking-wide w-max border border-white/30">
                            {recipe.tag}
                        </span>
                        <h2 class="font-serif text-3xl text-white font-bold mb-4 leading-tight">{recipe.title}</h2>
                        <p class="text-white/80 mb-8 font-sans text-base leading-relaxed">{recipe.description}</p>
                        <RecipeBuyButton client:load recipeId={recipe.id} recipeName={recipe.title} recipePrice={recipe.price} recipeImage={recipe.image} />
                    </div>
                </div>
            ))}
        </div>

        <!-- Inspiration Gallery -->
        <div class="mb-16">
            <h2 class="font-serif text-4xl text-primary italic text-center mb-10">Inspiración del horno</h2>
            <div class="grid grid-cols-3 md:grid-cols-6 gap-3">
                {inspirationImages.map((src) => (
                    <div class="aspect-square rounded-2xl overflow-hidden shadow-md hover:shadow-xl hover:scale-105 transition-all duration-500 cursor-pointer">
                        <img src={src} alt="Producto artesanal" class="w-full h-full object-cover" loading="lazy" />
                    </div>
                ))}
            </div>
        </div>

        <!-- CTA -->
        <div class="text-center bg-accent/10 rounded-3xl p-12 border border-accent/20">
            <h2 class="font-serif text-4xl text-primary italic mb-4">¿Prefieres que lo hagamos nosotros?</h2>
            <p class="text-gray-600 text-xl mb-8 font-serif">Olvídate de las recetas y déjanos hornear por ti. Pedidos frescos, semanal.</p>
            <a href="/checkout"><Button variant="primary" className="h-14 px-12 text-xl shadow-xl hover:scale-105 transition-transform">Hacer mi Pedido</Button></a>
        </div>
    </div>
</Layout>
