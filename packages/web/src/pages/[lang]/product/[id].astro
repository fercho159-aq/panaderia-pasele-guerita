---
import Layout from '../../../layouts/Layout.astro';
import { ProductDetail } from '../../../components/ProductDetail';
import { allProducts } from '@pasele-guerita/core';
import { isValidLang, type Language } from '../../../i18n/translations';

const { lang: langParam, id } = Astro.params;
if (!isValidLang(langParam)) {
    return Astro.redirect(`/es/product/${id}`);
}
const lang: Language = langParam;

// Find product directly in SSR mode, case-insensitive
let product = allProducts.find((p) => p.id?.toLowerCase() === id?.toLowerCase());

if (!product) {
    // If not in static config, check storefront API (last resort)
    try {
        const origin = Astro.url.origin;
        const res = await fetch(`${origin}/api/storefront-data`);
        if (res.ok) {
            const data = await res.json();
            const allStorefrontItems = [...(data.cookies || []), ...(data.breads || [])];
            product = allStorefrontItems.find((p: any) => p.id?.toLowerCase() === id?.toLowerCase());
        }
    } catch (e) {}
}

if (!product) {
    return Astro.redirect(`/${lang}`);
}
---

<Layout title={product.name} description={product.description} lang={lang}>
	<div class="bg-bg min-h-screen">
		<ProductDetail client:load product={product} lang={lang} />
	</div>
</Layout>
