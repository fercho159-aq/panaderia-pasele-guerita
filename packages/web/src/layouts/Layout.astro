---
import '../styles/global.css';
import { CartDrawer } from '../components/CartDrawer';
import { CartButton } from '../components/CartButton';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Artisanal Sourdough Dallas, Handmade Cookies" } = Astro.props;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Pásele Güerita</title>
		<meta name="description" content={description} />
		
		<!-- Fonts: Chunk Five Style (Alfa Slab One + Arvo) -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Alfa+Slab+One&family=Arvo:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet">
		
		<style is:global>
			:root {
				--font-heading: 'Alfa Slab One', serif;
				--font-body: 'Arvo', serif;
			}
			.font-serif { font-family: var(--font-heading) !important; font-weight: normal !important; }
			.font-sans { font-family: var(--font-body) !important; font-weight: 500 !important; }
		</style>
	</head>
	<body class="bg-bg font-sans text-gray-900">
		<CartDrawer client:load />
		<nav class="bg-white/80 backdrop-blur-md sticky top-0 z-50 border-b border-bg">
			<div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
				<a href="/" class="flex flex-col justify-center">
					<img src="/logo.png" alt="Pásele Güerita" class="h-24 sm:h-28 w-auto drop-shadow-sm" />
				</a>
				<div class="flex items-center space-x-8">
					<div class="hidden md:flex space-x-8 font-sans text-sm border-l border-primary/20 pl-8 uppercase tracking-widest mr-4">
						<a href="/" class="hover:text-accent transition-colors">Menú</a>
						<a href="/about" class="hover:text-accent transition-colors">Quiénes somos</a>
						<a href="/recipes" class="hover:text-accent transition-colors">Recetas</a>
					</div>
					<CartButton client:load />
				</div>
			</div>
		</nav>
		<main>
			<slot />
		</main>
		<!-- Global Photo Marquee – GPU optimized -->
		<div class="layout-marquee-wrap overflow-hidden bg-bg py-3 border-t border-b border-bg/30">
			<div class="layout-marquee-inner flex gap-3" aria-hidden="true">
				{[
					'/imagenes/hogaza-natural.webp','/imagenes/hogaza-centeno.webp','/imagenes/cookie-chai.webp',
					'/imagenes/hogaza-semillas.webp','/imagenes/hogaza-proceso.webp','/imagenes/IMG_6758.webp',
					'/imagenes/hogaza-natural.webp','/imagenes/hogaza-centeno.webp','/imagenes/cookie-chai.webp',
					'/imagenes/hogaza-semillas.webp','/imagenes/hogaza-proceso.webp','/imagenes/IMG_6758.webp',
				].map((src) => (
					<div class="flex-shrink-0 w-20 h-20 rounded-xl overflow-hidden border border-white/20">
						<img src={src} alt="" class="w-full h-full object-cover" loading="lazy" decoding="async" />
					</div>
				))}
			</div>
		</div>
		<style>
			.layout-marquee-wrap { height: 5.5rem; overflow: hidden; position: relative; }
			.layout-marquee-inner {
				position: absolute;
				display: flex;
				gap: 0.75rem;
				width: max-content;
				will-change: transform;
				animation: layout-scroll 30s linear infinite;
			}
			@keyframes layout-scroll {
				from { transform: translateX(0); }
				to   { transform: translateX(-50%); }
			}
		</style>
		<footer class="bg-primary text-bg py-12">
			<div class="max-w-7xl mx-auto px-6 text-center">
				<div class="bg-white p-1 rounded-2xl md:rounded-3xl inline-block mb-8 shadow-sm">
					<img src="/logo.png" alt="Pásele Güerita" class="h-20 md:h-24 w-auto mx-auto" />
				</div>
				<h2 class="font-serif text-4xl md:text-5xl mb-6">Hecho con masa madre y mucho amor.</h2>
				
                <div class="flex flex-col items-center gap-6 mb-10">
                    <div class="flex gap-8 items-center">
                        <a href="https://instagram.com/paselegueritatx" target="_blank" rel="noopener noreferrer" class="text-bg hover:text-accent transition-all hover:-translate-y-1 p-2 bg-white/10 rounded-xl" title="Instagram">
                            <svg viewBox="0 0 24 24" class="w-8 h-8 fill-current"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.266.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                        </a>
                        <a href="https://tiktok.com/@paselegueritatx" target="_blank" rel="noopener noreferrer" class="text-bg hover:text-accent transition-all hover:-translate-y-1 p-2 bg-white/10 rounded-xl" title="TikTok">
                            <svg viewBox="0 0 24 24" class="w-8 h-8 fill-current"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.9-.32-1.98-.23-2.81.33-.85.51-1.44 1.43-1.58 2.41-.14.99.11 2.07.71 2.87.45.58 1.08 1.02 1.74 1.27 1.25.46 2.76.22 3.76-.66.83-.7 1.17-1.72 1.22-2.77.01-4.94 0-9.87.01-14.81z"/></svg>
                        </a>
                        <a href="https://facebook.com/paselegueritatx" target="_blank" rel="noopener noreferrer" class="text-bg hover:text-accent transition-all hover:-translate-y-1 p-2 bg-white/10 rounded-xl" title="Facebook">
                            <svg viewBox="0 0 24 24" class="w-8 h-8 fill-current"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                        </a>
                    </div>

                    <div class="font-sans flex flex-wrap justify-center gap-x-8 gap-y-4 text-lg font-bold opacity-90 uppercase tracking-widest text-sm text-bg/90">
                        <a href="/" class="hover:text-accent transition-colors underline underline-offset-8 decoration-accent/30">Inicio</a>
                        <a href="/about" class="hover:text-accent transition-colors underline underline-offset-8 decoration-accent/30">Historia</a>
                        <a href="/policies" class="hover:text-accent transition-colors underline underline-offset-8 decoration-accent/30 text-accent font-black">Políticas</a>
                        <a href="/legal" class="hover:text-accent transition-colors underline underline-offset-8 decoration-accent/30">Aviso Legal</a>
                    </div>
                </div>

                <div class="font-sans text-bg/50 text-xs uppercase tracking-[0.2em] space-y-2">
                    <p>Dallas TX &bull; Farmersville TX</p>
                    <p>+1 430 324 2593 | @paselegueritatx</p>
                    <p class="mt-8 opacity-30">&copy; {new Date().getFullYear()} Pásele Güerita. All rights reserved.</p>
                </div>
			</div>
		</footer>
        <!-- Floating WhatsApp Button -->
        <a 
            href="https://wa.me/14303242593" 
            target="_blank" 
            rel="noopener noreferrer" 
            class="fixed bottom-8 right-8 z-[100] bg-[#25D366] text-white p-3 md:p-4 rounded-full shadow-2xl hover:scale-110 transition-transform active:scale-95 group focus:outline-none focus:ring-4 focus:ring-[#25D366]/50"
            aria-label="Contactar por WhatsApp"
        >
            <div class="relative">
                <svg viewBox="0 0 24 24" class="w-10 h-10 md:w-12 md:h-12 fill-current">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
                <span class="absolute -top-1 -right-1 flex h-4 w-4">
                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-white opacity-75"></span>
                    <span class="relative inline-flex rounded-full h-4 w-4 bg-white shadow-sm"></span>
                </span>
            </div>
            {/* Tooltip */}
            <span class="absolute right-full mr-4 top-1/2 -translate-y-1/2 bg-white text-primary px-4 py-2 rounded-xl text-sm font-bold shadow-xl border border-accent/10 whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none">
                ¿En qué podemos ayudarte?
            </span>
        </a>
	</body>
</html>
