---
import Layout from '../layouts/Layout.astro';
import { Button } from '@pasele-guerita/ui';
import { Card } from '@pasele-guerita/ui';
import { Badge } from '@pasele-guerita/ui';
import { cookieFlavors, breadFlavors, monthlySpecial } from '@pasele-guerita/core';

// Fetch live products from the database at render time
let displayCookies: any[] = cookieFlavors;
let displayBreads: any[] = breadFlavors;
try {
    const origin = Astro.url.origin;
    const res = await fetch(`${origin}/api/storefront-data`);
    if (res.ok) {
        const data = await res.json();
        if (data.cookies?.length > 0) displayCookies = data.cookies;
        if (data.breads?.length > 0) displayBreads = data.breads;
    }
} catch (e) {
    console.error("Could not fetch live products for homepage, using fallback:", e);
}
---

<Layout title="Home">
	<!-- Announcement Bar for Scarcity -->
	<div class="bg-accent text-primary text-center py-3 font-bold text-sm tracking-wide">
		Próxima entrega: Sábado 18 de Noviembre. ¡Quedan pocos lugares!
	</div>

	<!-- Hero Section (Problem & Solution Intro) -->
	<section class="py-20 bg-white border-b border-bg relative overflow-hidden">
		<div class="max-w-7xl mx-auto px-6 grid md:grid-cols-2 gap-12 items-center">
			<div>
				<Badge variant="accent" className="mb-6">Lotes Pequeños</Badge>
				<h1 class="text-6xl md:text-7xl font-serif font-bold text-primary mb-6 leading-tight">
					¿Cansado del pan que inflama tu cuerpo?
				</h1>
				<p class="text-2xl text-gray-700 font-bold mb-8 max-w-lg leading-relaxed font-serif italic">
					En Dallas, encontrar pan artesanal real es un reto. Olvida los conservadores del supermercado.
				</p>
				<p class="text-lg text-gray-700 mb-10 max-w-lg">
					Sourdough con corazón. Fermentación lenta de 24 horas, sin azúcar añadida (opciones Sugar Free) y con ingredientes que tu cuerpo sí reconoce.
				</p>
				<div class="flex flex-col sm:flex-row gap-4">
					<a href="#menu"><Button variant="outline" className="w-full sm:w-auto text-lg h-14 px-8">Ver Menú</Button></a>
					<a href="/checkout"><Button variant="primary" className="w-full sm:w-auto text-lg h-14 px-8 shadow-lg">Reservar Ahora</Button></a>
				</div>
			</div>
			<div class="relative mt-10 md:mt-0">
				<div class="aspect-square rounded-full bg-accent/20 absolute -top-10 -left-10 w-64 h-64 -z-10 animate-pulse"></div>
				<img src="https://images.unsplash.com/photo-1558961363-fa8fdf82db35?q=80&w=1000" alt="Sourdough Cookies" class="rounded-3xl shadow-2xl rotate-3 hover:rotate-0 transition-transform duration-500 w-full object-cover" />
			</div>
		</div>
	</section>

	<!-- Agitation (Scarcity & Urgency) -->
	<section class="py-24 bg-bg">
		<div class="max-w-4xl mx-auto px-6 text-center">
			<h2 class="font-serif text-4xl md:text-5xl text-primary mb-8 leading-tight">Nuestra producción es limitada.</h2>
			<p class="text-xl text-gray-700 leading-relaxed mb-10 max-w-2xl mx-auto">
				Horneamos lotes pequeños para garantizar la calidad. Solo abrimos pedidos una vez al mes. 
				<strong class="text-primary block mt-4 text-2xl italic font-serif">Si parpadeas, te quedas sin tu Sourdough.</strong>
			</p>
			<Badge variant="error" className="text-sm md:text-base px-6 py-3">Cupos limitados por punto de entrega</Badge>
		</div>
	</section>

	<!-- Testimonials (Authority) -->
	<section class="py-24 bg-white border-y border-bg">
		<div class="max-w-7xl mx-auto px-6">
			<h2 class="font-serif text-3xl md:text-4xl text-center text-primary mb-16 italic font-medium">"Hecho en Dallas para los que extrañan el sabor real de casa."</h2>
			<div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
				<div class="bg-bg p-8 md:p-10 rounded-3xl relative hover:-translate-y-2 transition-transform duration-300">
					<span class="text-7xl text-accent absolute -top-6 left-6 font-serif opacity-50">"</span>
					<p class="text-gray-700 text-lg mb-6 italic mt-4 relative z-10">El primer pan en años que no me inflama. Las galletas de Matcha son espectaculares.</p>
					<p class="font-bold text-primary">— Mariana L., Uptown</p>
				</div>
				<div class="bg-bg p-8 md:p-10 rounded-3xl relative hover:-translate-y-2 transition-transform duration-300">
					<span class="text-7xl text-accent absolute -top-6 left-6 font-serif opacity-50">"</span>
					<p class="text-gray-700 text-lg mb-6 italic mt-4 relative z-10">Vale cada centavo. Se nota el amor y las 24 horas de fermentación. No vuelvo al pan de caja.</p>
					<p class="font-bold text-primary">— Roberto C., Oak Cliff</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Offer & Response (Products Section) -->
	<section id="menu" class="py-24 max-w-7xl mx-auto px-6">
		<div class="text-center mb-16">
			<h2 class="font-serif text-5xl md:text-6xl text-primary mb-6 italic">Asegura tu pedido</h2>
			<p class="text-xl text-gray-600 mb-4">Antes de que el horno se llene.</p>
			<p class="text-3xl font-bold text-gray-500 font-serif italic mb-10">Especial del mes: {monthlySpecial.name}</p>
			<a href="/checkout"><Button variant="primary" className="text-xl px-12 h-16 shadow-xl hover:scale-105 transition-transform duration-300">Hacer Pedido Ahora</Button></a>
		</div>
		
		{/* Galletas */}
		<div class="mb-16">
			<h3 class="font-serif text-3xl text-primary italic mb-2">🍪 Galletas Artesanales</h3>
			<p class="text-gray-500 mb-8 text-sm">Set de 3 galletas por caja &bull; Horneadas con masa madre</p>
			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
				{displayCookies.map((flavor: any) => (
					<Card title={flavor.name} price={flavor.price || 12} description={flavor.description || 'Galleta artesanal horneada con masa madre.'}>
						<a href="/checkout"><Button variant="accent" className="w-full">Agregar al Carrito</Button></a>
					</Card>
				))}
			</div>
		</div>

		{/* Pan de Masa Madre */}
		<div>
			<h3 class="font-serif text-3xl text-primary italic mb-2">🍞 Pan de Masa Madre</h3>
			<p class="text-gray-500 mb-8 text-sm">Hogaza entera &bull; Fermentación lenta 48 horas</p>
			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
				{displayBreads.map((bread: any) => (
					<Card title={bread.name} price={bread.price || 18} description={bread.description || 'Pan artesanal de masa madre.'}>
						<a href="/checkout"><Button variant="accent" className="w-full">Agregar al Carrito</Button></a>
					</Card>
				))}
			</div>
		</div>
	</section>
</Layout>
