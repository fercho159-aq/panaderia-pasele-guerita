---
// Root index redirects to default language. Detects browser preference
// (Accept-Language header) and routes to /es or /en accordingly.
const acceptLanguage = Astro.request.headers.get('accept-language') ?? '';
const prefersEnglish = /^en\b|,\s*en\b/i.test(acceptLanguage) && !/^es\b|,\s*es\b/i.test(acceptLanguage);
const target = prefersEnglish ? '/en' : '/es';
return Astro.redirect(target, 302);
