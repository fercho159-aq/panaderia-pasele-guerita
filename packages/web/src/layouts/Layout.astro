---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Artisanal Sourdough Dallas, Handmade Cookies" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Pásele Güerita</title>
		<meta name="description" content={description} />
		
		<!-- SEO -->
		<meta name="keywords" content="Artisanal Sourdough Dallas, Limited Edition Cookies, Healthy Bread Dallas, Texas Bakery" />
		<!-- LocalBusiness Schema -->
		<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@type": "LocalBusiness",
			"name": "Pásele Güerita",
			"image": "https://paseleguerita.com/logo.png",
			"address": {
				"@type": "PostalAddress",
				"addressLocality": "Dallas",
				"addressRegion": "TX",
				"addressCountry": "US"
			},
			"description": "Artisanal Sourdough Bakery in Dallas, Texas.",
			"priceRange": "$$"
		}
		</script>
	</head>
	<body class="bg-bg font-sans text-gray-900">
		<nav class="bg-white/80 backdrop-blur-md sticky top-0 z-50 border-b border-bg">
			<div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
				<a href="/" class="flex flex-col justify-center">
					<img src="/logo.png" alt="Pásele Güerita" class="h-20 sm:h-24 w-auto drop-shadow-sm" />
				</a>
				<div class="hidden md:flex space-x-8 font-serif text-2xl font-bold border-l border-primary/20 pl-8">
					<a href="/" class="hover:text-accent transition-colors">Menú</a>
					<a href="/about" class="hover:text-accent transition-colors">Quiénes somos</a>
					<a href="/recipes" class="hover:text-accent transition-colors">Recetas</a>
					<a href="/checkout" class="text-primary hover:text-accent font-black transition-colors">Carrito</a>
				</div>
                <div class="md:hidden">
                    <a href="/checkout" class="text-primary font-serif font-black text-2xl">Carrito</a>
                </div>
			</div>
		</nav>
		<main>
			<slot />
		</main>
		<footer class="bg-primary text-bg py-12 mt-20">
			<div class="max-w-7xl mx-auto px-6 text-center">
				<div class="bg-white p-3 rounded-2xl md:rounded-3xl inline-block mb-8 shadow-sm">
					<img src="/logo.png" alt="Pásele Güerita" class="h-16 md:h-20 w-auto mx-auto" />
				</div>
				<h2 class="font-serif text-4xl md:text-5xl font-bold mb-6 italic">Hecho con masa madre y mucho amor.</h2>
				
                <div class="flex flex-col items-center gap-6 mb-10">
                    <div class="flex gap-10 text-3xl">
                        <a href="https://instagram.com/paselegueritatx" target="_blank" rel="noopener noreferrer" class="hover:text-accent transition-all hover:-translate-y-1" title="Instagram">📸</a>
                        <a href="https://tiktok.com/@paselegueritatx" target="_blank" rel="noopener noreferrer" class="hover:text-accent transition-all hover:-translate-y-1" title="TikTok">🎵</a>
                        <a href="https://facebook.com/paselegueritatx" target="_blank" rel="noopener noreferrer" class="hover:text-accent transition-all hover:-translate-y-1" title="Facebook">👥</a>
                    </div>

                    <div class="font-sans flex flex-wrap justify-center gap-x-8 gap-y-4 text-lg font-bold opacity-90 uppercase tracking-widest text-sm text-bg/90">
                        <a href="/" class="hover:text-accent transition-colors underline underline-offset-8 decoration-accent/30">Inicio</a>
                        <a href="/about" class="hover:text-accent transition-colors underline underline-offset-8 decoration-accent/30">Historia</a>
                        <a href="/policies" class="hover:text-accent transition-colors underline underline-offset-8 decoration-accent/30 text-accent font-black">Políticas</a>
                        <a href="/legal" class="hover:text-accent transition-colors underline underline-offset-8 decoration-accent/30">Aviso Legal</a>
                    </div>
                </div>

                <div class="font-sans text-bg/50 text-xs uppercase tracking-[0.2em] space-y-2">
                    <p>Dallas TX &bull; Farmersville TX</p>
                    <p>+1 430 324 2593 | @paselegueritatx</p>
                    <p class="mt-8 opacity-30">&copy; {new Date().getFullYear()} Pásele Güerita. All rights reserved.</p>
                </div>
			</div>
		</footer>
        <!-- Floating WhatsApp Button -->
        <a 
            href="https://wa.me/14303242593" 
            target="_blank" 
            rel="noopener noreferrer" 
            class="fixed bottom-8 right-8 z-[100] bg-[#25D366] text-white p-4 rounded-full shadow-2xl hover:scale-110 transition-transform active:scale-95 group focus:outline-none focus:ring-4 focus:ring-[#25D366]/50"
            aria-label="Contactar por WhatsApp"
        >
            <div class="relative">
                <span class="text-4xl">💬</span>
                <span class="absolute -top-1 -right-1 flex h-3 w-3">
                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-white opacity-75"></span>
                    <span class="relative inline-flex rounded-full h-3 w-3 bg-white shadow-sm"></span>
                </span>
            </div>
            {/* Tooltip */}
            <span class="absolute right-full mr-4 top-1/2 -translate-y-1/2 bg-white text-primary px-4 py-2 rounded-xl text-sm font-bold shadow-xl border border-accent/10 whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none">
                ¿En qué podemos ayudarte?
            </span>
        </a>
	</body>
</html>
