---
import Layout from '../../layouts/Layout.astro';
import { isValidLang, useTranslations, type Language } from '../../i18n/translations';

const { lang: langParam } = Astro.params;
if (!isValidLang(langParam)) {
    return Astro.redirect('/es/legal');
}
const lang: Language = langParam;
const tr = useTranslations(lang);
---

<Layout title={tr('legal.metaTitle')} description={tr('legal.metaDescription')} lang={lang}>
    <div class="max-w-3xl mx-auto px-6 py-20 animate-fade-in text-gray-800">
        <h1 class="font-serif text-6xl text-primary mb-12 italic border-b border-bg pb-6">{tr('legal.heading')}</h1>

        <div class="prose prose-lg max-w-none font-sans">
            <h2 class="text-3xl font-bold text-primary mb-4">{tr('legal.productionTitle')}</h2>
            <p class="mb-8 p-6 bg-red-50 text-red-900 border border-red-200 rounded-xl font-bold">
                {tr('legal.homeKitchen')}
            </p>

            <h3 class="text-2xl font-bold text-primary mb-4">{tr('legal.cottageLawTitle')}</h3>
            <p class="mb-6" set:html={tr('legal.cottageLawText')}></p>

            <h3 class="text-2xl font-bold text-primary mb-4">{tr('legal.allergensTitle')}</h3>
            <p class="mb-6" set:html={tr('legal.allergensText')}></p>

            <h3 class="text-2xl font-bold text-primary mb-4">{tr('legal.salesTitle')}</h3>
            <p>{tr('legal.salesText')}</p>
        </div>
    </div>
</Layout>
