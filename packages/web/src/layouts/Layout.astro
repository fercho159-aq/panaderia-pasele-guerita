---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Artisanal Sourdough Dallas, Handmade Cookies" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Pásele Güerita</title>
		<meta name="description" content={description} />
		
		<!-- SEO -->
		<meta name="keywords" content="Artisanal Sourdough Dallas, Limited Edition Cookies, Healthy Bread Dallas, Texas Bakery" />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet">
		
		<!-- LocalBusiness Schema -->
		<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@type": "LocalBusiness",
			"name": "Pásele Güerita",
			"image": "https://paseleguerita.com/logo.png",
			"address": {
				"@type": "PostalAddress",
				"addressLocality": "Dallas",
				"addressRegion": "TX",
				"addressCountry": "US"
			},
			"description": "Artisanal Sourdough Bakery in Dallas, Texas.",
			"priceRange": "$$"
		}
		</script>
	</head>
	<body class="bg-bg font-sans text-gray-900">
		<nav class="bg-white/80 backdrop-blur-md sticky top-0 z-50 border-b border-bg">
			<div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
				<a href="/" class="font-serif text-3xl font-bold text-primary italic">Pásele Güerita</a>
				<div class="space-x-8 font-serif">
					<a href="/" class="hover:text-accent">Menu</a>
					<a href="/checkout" class="hover:text-accent">Cart</a>
				</div>
			</div>
		</nav>
		<main>
			<slot />
		</main>
		<footer class="bg-primary text-white py-12 mt-20">
			<div class="max-w-7xl mx-auto px-6 text-center">
				<h2 class="font-serif text-3xl mb-4 italic">Hecho con masa madre y mucho amor.</h2>
				<p class="font-sans text-white/80">Dallas, Texas | Artisanal Bakery</p>
			</div>
		</footer>
	</body>
</html>
