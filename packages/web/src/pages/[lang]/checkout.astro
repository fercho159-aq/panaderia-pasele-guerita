---
import Layout from '../../layouts/Layout.astro';
import { CheckoutFlow } from '../../components/CheckoutFlow';
import { isValidLang, useTranslations, type Language } from '../../i18n/translations';

const { lang: langParam } = Astro.params;
if (!isValidLang(langParam)) {
    return Astro.redirect('/es/checkout');
}
const lang: Language = langParam;
const tr = useTranslations(lang);
---

<Layout title={tr('checkoutPage.title')} description={tr('meta.defaultDescription')} lang={lang}>
	<section class="py-20 bg-white">
		<div class="max-w-7xl mx-auto px-6 text-center">
			<h1 class="font-serif text-6xl text-primary mb-4 italic">{tr('checkoutPage.title')}</h1>
			<p class="text-gray-500 text-xl font-serif">{tr('checkoutPage.subtitle')}</p>
		</div>
	</section>

	<section class="pb-32 px-6">
		<CheckoutFlow client:load lang={lang} />
	</section>
</Layout>
