---
import Layout from '../../layouts/Layout.astro';
import { Button } from '@pasele-guerita/ui';
import { AddToCartButton } from '../../components/AddToCartButton';
import { cookieFlavors, breadFlavors } from '@pasele-guerita/core';
import { isValidLang, useTranslations, localizedPath, type Language } from '../../i18n/translations';

const { lang: langParam } = Astro.params;
if (!isValidLang(langParam)) {
    return Astro.redirect('/es/menu');
}
const lang: Language = langParam;
const tr = useTranslations(lang);

// Use hardcoded lists as canonical — DB only determines active/inactive status.
// `null` means the API failed and we fall back to showing everything (avoids
// breaking the storefront on connectivity issues). An empty array from the API
// is a legitimate state (admin turned all OFF) and must be respected.
let activeCookieIds: Set<string> | null = null;
let activeBreadIds: Set<string> | null = null;
try {
    const origin = Astro.url.origin;
    const res = await fetch(`${origin}/api/storefront-data`);
    if (res.ok) {
        const data = await res.json();
        if (Array.isArray(data.cookies)) activeCookieIds = new Set(data.cookies.map((c: any) => c.id));
        if (Array.isArray(data.breads)) activeBreadIds = new Set(data.breads.map((b: any) => b.id));
    }
} catch (e) {}

const displayCookies = activeCookieIds ? cookieFlavors.filter(c => activeCookieIds!.has(c.id)) : cookieFlavors;
const displayBreads = activeBreadIds ? breadFlavors.filter(b => activeBreadIds!.has(b.id)) : breadFlavors;

const regularCookies = displayCookies.filter((c: any) => !c.is_sugar_free);
const sugarFreeCookies = displayCookies.filter((c: any) => c.is_sugar_free);

const categories = [
    { id: 'all', name: tr('menu.categories.all') },
    { id: 'regulares', name: tr('menu.categories.regulares') },
    { id: 'sugar-free', name: tr('menu.categories.sugarFree') },
    { id: 'pan', name: tr('menu.categories.pan') },
];

const priceEach = tr('menu.priceEach');
const viewDetailsLabel = tr('menu.viewDetails');
const productPath = (id: string) => localizedPath(lang, `/product/${id}`);
---

<Layout title={tr('menu.title')} lang={lang}>
    <div class="bg-[#FCF9F6] min-h-screen pb-20">
        <!-- Hero Header -->
        <header class="py-20 px-6 text-center bg-white border-b border-bg/20">
            <h1 class="font-serif text-5xl md:text-7xl text-primary mb-6 italic">{tr('menu.heading')}</h1>
            <p class="font-sans text-xl text-gray-600 max-w-2xl mx-auto italic">
                {tr('menu.subtitle')}
            </p>
        </header>

        <!-- Sticky Category Nav -->
        <nav class="sticky top-[80px] sm:top-[96px] z-30 bg-white/95 backdrop-blur-md border-b border-bg/20 shadow-sm py-3 md:py-4">
            <div class="max-w-7xl mx-auto px-4 md:px-6">
                <div class="flex flex-col md:flex-row md:justify-center gap-2 md:gap-8">
                    {categories.map((cat) => (
                        <a
                            href={`#${cat.id}`}
                            class="px-5 py-3 md:py-2 rounded-xl md:rounded-full font-serif text-base md:text-lg text-primary bg-primary/5 md:bg-transparent hover:bg-primary hover:text-white transition-all border border-primary/10 md:border-transparent md:hover:border-primary/10 active:scale-95 text-center font-bold"
                        >
                            {cat.name}
                        </a>
                    ))}
                </div>
            </div>
        </nav>

        <div class="max-w-7xl mx-auto px-6 space-y-24 pt-16" id="all">

            <!-- Section: Galletas Regulares -->
            <section id="regulares" class="scroll-mt-32">
                <div class="mb-12 border-b border-primary/10 pb-4">
                    <h2 class="font-serif text-4xl text-primary italic">{tr('menu.sections.regulares.title')}</h2>
                    <p class="text-gray-500 font-sans mt-2 tracking-widest uppercase text-xs font-bold">{tr('menu.sections.regulares.subtitle')}</p>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
                    {regularCookies.map((flavor) => (
                        <div class="group bg-white rounded-[2.5rem] overflow-hidden shadow-sm hover:shadow-xl transition-all duration-500 flex flex-col border border-bg/20">
                            <div class="relative h-64 overflow-hidden bg-gray-50">
                                <img src={flavor.image} alt={flavor.name} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
                                <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                            </div>
                            <div class="p-8 flex-1 flex flex-col">
                                <h3 class="font-serif text-2xl text-primary mb-1 italic">{flavor.name}</h3>
                                <span class="text-lg font-bold text-primary font-serif italic mb-3">${flavor.price ? (flavor.price/3).toFixed(2) : '4.00'} {priceEach}</span>
                                <p class="text-sm text-gray-600 flex-1 line-clamp-3">{flavor.description}</p>
                                <a href={productPath(flavor.id)} class="block mt-6 w-full text-center text-sm font-bold bg-primary text-white hover:bg-accent hover:scale-[1.02] active:scale-95 transition-all duration-200 py-3 px-6 rounded-xl shadow-sm hover:shadow-md">
                                    {viewDetailsLabel}
                                </a>
                            </div>
                        </div>
                    ))}
                </div>
            </section>

            <!-- Section: Galletas Sugar Free -->
            <section id="sugar-free" class="scroll-mt-32">
                <div class="mb-12 border-b border-primary/10 pb-4">
                    <h2 class="font-serif text-4xl text-primary italic">{tr('menu.sections.sugarFree.title')}</h2>
                    <p class="text-gray-500 font-sans mt-2 tracking-widest uppercase text-xs font-bold">{tr('menu.sections.sugarFree.subtitle')}</p>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
                    {sugarFreeCookies.map((flavor) => (
                        <div class="group bg-white rounded-[2.5rem] overflow-hidden shadow-sm hover:shadow-xl transition-all duration-500 flex flex-col border border-accent/20 border-dashed">
                             <div class="relative h-64 overflow-hidden bg-gray-50">
                                <img src={flavor.image} alt={flavor.name} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
                                <div class="absolute top-4 right-4 bg-accent/90 text-white text-[10px] font-bold uppercase px-3 py-1 rounded-full shadow-sm">{tr('menu.sugarFreeBadge')}</div>
                            </div>
                            <div class="p-8 flex-1 flex flex-col">
                                <h3 class="font-serif text-2xl text-primary mb-1 italic">{flavor.name}</h3>
                                <span class="text-lg font-bold text-primary font-serif italic mb-3">${flavor.price ? (flavor.price/3).toFixed(2) : '4.50'} {priceEach}</span>
                                <p class="text-sm text-gray-600 flex-1 line-clamp-3">{flavor.description}</p>
                                <a href={productPath(flavor.id)} class="block mt-6 w-full text-center text-sm font-bold bg-primary text-white hover:bg-accent hover:scale-[1.02] active:scale-95 transition-all duration-200 py-3 px-6 rounded-xl shadow-sm hover:shadow-md">
                                    {viewDetailsLabel}
                                </a>
                            </div>
                        </div>
                    ))}
                </div>
            </section>

            <!-- Section: Pan -->
            <section id="pan" class="scroll-mt-32">
                <div class="mb-12 border-b border-primary/10 pb-4">
                    <h2 class="font-serif text-4xl text-primary italic">{tr('menu.sections.pan.title')}</h2>
                    <p class="text-gray-500 font-sans mt-2 tracking-widest uppercase text-xs font-bold">{tr('menu.sections.pan.subtitle')}</p>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
                    {displayBreads.map((flavor: any) => (
                        <div class="group bg-white rounded-[2.5rem] overflow-hidden shadow-sm hover:shadow-xl transition-all duration-500 flex flex-col border border-bg/20">
                            <div class="relative h-72 overflow-hidden bg-gray-50">
                                <img src={flavor.image} alt={flavor.name} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
                            </div>
                            <div class="p-8 flex-1 flex flex-col text-center">
                                <h3 class="font-serif text-3xl text-primary mb-1 italic">{flavor.name}</h3>
                                <span class="text-2xl font-bold text-primary font-serif italic mb-3">${flavor.price}</span>
                                <p class="text-sm text-gray-600 flex-1">{flavor.description}</p>
                                <a href={productPath(flavor.id)} class="block mt-6 w-full text-center text-sm font-bold bg-primary text-white hover:bg-accent hover:scale-[1.02] active:scale-95 transition-all duration-200 py-3 px-6 rounded-xl shadow-sm hover:shadow-md">
                                    {viewDetailsLabel}
                                </a>
                            </div>
                        </div>
                    ))}
                </div>
            </section>
        </div>
    </div>
</Layout>

<script>
    // Smooth scrolling only for in-page anchor links (href starting with #)
    document.querySelectorAll('nav a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function (e) {
            e.preventDefault();
            const targetId = (this as HTMLAnchorElement).getAttribute('href')!.substring(1);
            const targetElement = document.getElementById(targetId);
            if (targetElement) {
                targetElement.scrollIntoView({ behavior: 'smooth' });
            }
        });
    });
</script>
